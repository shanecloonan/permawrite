# P32 role template: wallet client (local laptop or dedicated signing host).
# Copy to vps-role-wallet.env. Never point --rpc at your own validator.
#
# See docs/REFERENCE_TOPOLOGY.md §4 and docs/TOR_P2P.md (B8.3).

MFN_REPO_ROOT=/opt/permawrite
MFN_WALLET=~/permawrite/wallet.json

# Preferred: SSH tunnel to observer RPC, then:
#   mfn-cli --rpc 127.0.0.1:18731 wallet …
# Or export for scripts that wrap mfn-cli:
MFN_RPC_URL=http://127.0.0.1:18731
MFN_RPC_API_KEY=REPLACE_IF_OBSERVER_REQUIRES_AUTH

# Optional: signed checkpoint log cross-check after light-scan (F12 phase 2)
# MFN_CHECKPOINT_LOG=~/permawrite/checkpoints.jsonl

# Remote privacy path (Tor hidden service on observer):
# MFN_CLI_RPC_TOR=1
# mfn-cli --tor --rpc YOURSEED.onion:18731 wallet …
