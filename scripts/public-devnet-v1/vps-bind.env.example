# VPS public P2P binds for single-box internet-facing testnet (Lane 7 / TL-4).
# Copy to vps-bind.env and adjust ports for your host firewall.
#
# RPC stays loopback-only; operators use SSH -L (see docs/VPS_SINGLE_BOX_LAUNCH.md).
# P2P uses 0.0.0.0 so peers can dial the VPS public IP.

# Hub (validator 0)
MFN_RPC_LISTEN_HUB=127.0.0.1:18731
MFN_P2P_LISTEN_HUB=0.0.0.0:19001

# Committee voters
MFN_RPC_LISTEN_V1=127.0.0.1:18732
MFN_P2P_LISTEN_V1=0.0.0.0:19002
MFN_RPC_LISTEN_V2=127.0.0.1:18733
MFN_P2P_LISTEN_V2=0.0.0.0:19003

# Observer (wallet/RPC tunnel target)
MFN_RPC_LISTEN_OBSERVER=127.0.0.1:18734
MFN_P2P_LISTEN_OBSERVER=0.0.0.0:19004

# Publish these in public_devnet_v1.manifest.json seed_nodes (P2P only):
#   YOUR_VPS_PUBLIC_IP:19001
#   YOUR_VPS_PUBLIC_IP:19002
#   YOUR_VPS_PUBLIC_IP:19003
# Optional fourth seed for observer P2P: YOUR_VPS_PUBLIC_IP:19004

# PM23 phase 4c: abort mfnd when validator/wallet env colocates operator manifests on VPS.
MFND_PM23_HARD_FAIL=1
