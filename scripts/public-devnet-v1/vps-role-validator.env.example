# P32 role template: dedicated validator VPS (hub or committee voter).
# Copy to vps-role-validator.env and fill secrets before launch.
#
# NEVER bind --rpc-listen to 0.0.0.0 on a --produce / --committee-vote host.
# See docs/REFERENCE_TOPOLOGY.md and mfnd_role_topology_warning.

# Validator identity (0 = hub --produce; 1|2 = committee voter)
MFND_VALIDATOR_INDEX=0
MFND_VRF_SEED_HEX=REPLACE_WITH_64_HEX
MFND_BLS_SEED_HEX=REPLACE_WITH_64_HEX

# Paths
MFN_REPO_ROOT=/opt/permawrite
MFN_DATA_DIR=/var/lib/mfnd-validator
GENESIS_SPEC=mfn-node/testdata/public_devnet_v1.json
SLOT_MS=30000

# Loopback RPC only (operators/wallets use observer RPC)
MFN_RPC_LISTEN=127.0.0.1:18731
# Public P2P — publish YOUR_PUBLIC_IP:PORT in manifest seed_nodes
MFN_P2P_LISTEN=0.0.0.0:19001

# Bootstrap peers (other validators' public P2P addresses)
# Used by manual mfnd launch or export as HUB_P2P / EXTRA_P2P_DIALS for start-*.sh
MFN_P2P_DIAL_PEERS=203.0.113.11:19002 203.0.113.12:19003

# Optional: checkpoint anchor peers from signed log (F12)
# MFN_P2P_ANCHOR_SUMMARY=/path/to/trusted-summary.json
