# P32 role template: storage operator (RPC-only — no mfnd validator on this host).
# Copy to vps-role-operator.env. Point MFN_RPC at an observer, never a validator.
#
# See docs/REFERENCE_TOPOLOGY.md §3.3 and start-storage-operator.sh.

MFN_REPO_ROOT=/opt/permawrite

# Observer RPC URL (cleartext or SSH tunnel target)
MFN_RPC=http://203.0.113.14:18731
MFN_RPC_API_KEY=REPLACE_IF_OBSERVER_REQUIRES_AUTH

# Operator wallet (payout keys) — generate on this host only
MFN_WALLET=/var/lib/permawrite-operator/wallet.json
MFN_OPERATOR_DATA=/var/lib/permawrite-operator/data

# Optional chunk HTTP serve (prefer tunnel/Tor in production)
# MFN_OPERATOR_CHUNK_LISTEN=127.0.0.1:8080
