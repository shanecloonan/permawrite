# P32 role template: dedicated observer VPS (community RPC + P2P sync).
# Copy to vps-role-observer.env before launch.
#
# Observers may expose public RPC; validators must not. See docs/REFERENCE_TOPOLOGY.md.

MFN_REPO_ROOT=/opt/permawrite
MFN_DATA_DIR=/var/lib/mfnd-observer
GENESIS_SPEC=mfn-node/testdata/public_devnet_v1.json
SLOT_MS=30000

# Public RPC for wallets/operators (enable API key for write methods)
MFN_RPC_LISTEN=0.0.0.0:18731
MFND_RPC_API_KEY=REPLACE_WITH_LONG_RANDOM_SECRET

# Public P2P (optional fourth seed in manifest)
MFN_P2P_LISTEN=0.0.0.0:19004

# Hub + voter public P2P dials (whitespace-separated for start-observer.sh EXTRA_P2P_DIALS)
HUB_P2P=203.0.113.10:19001
EXTRA_P2P_DIALS="203.0.113.11:19002 203.0.113.12:19003"

# Publish in invite docs / manifest observer_rpc (not validator RPC):
# MFN_OBSERVER_RPC_URL=http://YOUR_OBSERVER_PUBLIC_IP:18731
