# Shared GHA/local poll ceilings for start-all + participant-rehearsal-smoke (M2.5.43).
# Source from bash scripts after config.env; override via env for experiments.
if [[ -n "${GITHUB_ACTIONS:-}" ]]; then
  MFN_POLL_HUB_MAX="${MFN_POLL_HUB_MAX:-900}"
  MFN_POLL_VOTER_P2P_MAX="${MFN_POLL_VOTER_P2P_MAX:-900}"
  MFN_POLL_VOTER_DIAL_MAX="${MFN_POLL_VOTER_DIAL_MAX:-900}"
  MFN_POLL_OBSERVER_MAX="${MFN_POLL_OBSERVER_MAX:-900}"
  MFN_MESH_HEALTH_TIMEOUT="${MFN_MESH_HEALTH_TIMEOUT:-900}"
  MFN_HUB_LIVENESS_WAIT="${MFN_HUB_LIVENESS_WAIT:-900}"
  MFN_HUB_LIVENESS_MIN="${MFN_HUB_LIVENESS_MIN:-2}"
else
  MFN_POLL_HUB_MAX="${MFN_POLL_HUB_MAX:-60}"
  MFN_POLL_VOTER_P2P_MAX="${MFN_POLL_VOTER_P2P_MAX:-60}"
  MFN_POLL_VOTER_DIAL_MAX="${MFN_POLL_VOTER_DIAL_MAX:-120}"
  MFN_POLL_OBSERVER_MAX="${MFN_POLL_OBSERVER_MAX:-60}"
  MFN_MESH_HEALTH_TIMEOUT="${MFN_MESH_HEALTH_TIMEOUT:-420}"
  MFN_HUB_LIVENESS_WAIT="${MFN_HUB_LIVENESS_WAIT:-120}"
  MFN_HUB_LIVENESS_MIN="${MFN_HUB_LIVENESS_MIN:-1}"
fi
export MFN_POLL_HUB_MAX MFN_POLL_VOTER_P2P_MAX MFN_POLL_VOTER_DIAL_MAX
export MFN_POLL_OBSERVER_MAX MFN_MESH_HEALTH_TIMEOUT
export MFN_HUB_LIVENESS_WAIT MFN_HUB_LIVENESS_MIN
